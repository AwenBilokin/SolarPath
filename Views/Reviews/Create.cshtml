@model SolarPath.Web.Models.Review
@{ViewData["Title"] = "Залишити відгук";}

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="auth-card">
      <h4 class="fw-800 mb-1" style="letter-spacing:-.02em;">
        <i class="bi bi-star-fill text-warning me-2"></i>Залишити відгук
      </h4>
      <p class="text-muted mb-4" style="font-size:.875rem;">
        Маршрут: <strong>@ViewBag.Route?.Title</strong>
      </p>

      <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RouteId"/>

        <div class="mb-3">
          <label class="form-label">Оцінка</label>
          <div class="d-flex gap-2" id="starRating">
            @for (int i = 1; i <= 5; i++) {
              <button type="button" class="btn btn-outline-warning star-btn"
                      data-value="@i" style="font-size:1.5rem;padding:4px 10px;"
                      onclick="setRating(@i)">★</button>
            }
          </div>
          <input type="hidden" asp-for="Rating" id="ratingInput" value="5"/>
        </div>

        <div class="mb-4">
          <label class="form-label">Коментар</label>
          <textarea asp-for="Text" class="form-control" rows="4"
                    placeholder="Розкажіть про свої враження від походу..."></textarea>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-success">
            <i class="bi bi-send me-2"></i>Опублікувати відгук
          </button>
          <a asp-controller="Routes" asp-action="Details" asp-route-id="@Model.RouteId"
             class="btn btn-outline-secondary">Скасувати</a>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
function setRating(val) {
  document.getElementById('ratingInput').value = val;
  document.querySelectorAll('.star-btn').forEach((btn, i) => {
    btn.classList.toggle('btn-warning', i < val);
    btn.classList.toggle('btn-outline-warning', i >= val);
  });
}
setRating(5);
</script>
}
