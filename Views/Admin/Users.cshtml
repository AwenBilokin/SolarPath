@model IEnumerable<(SolarPath.Web.Models.ApplicationUser User, IList<string> Roles)>
@{ViewData["Title"] = "Управління користувачами";}

<h2 class="mb-4 fw-bold">Користувачі</h2>
<div class="table-responsive">
<table class="table table-hover align-middle">
  <thead class="table-dark">
    <tr><th>Ім'я</th><th>Email</th><th>Роль</th><th>Змінити роль</th></tr>
  </thead>
  <tbody>
  @foreach (var (user, roles) in Model)
  {
    <tr>
      <td>@user.FullName</td>
      <td>@user.Email</td>
      <td><span class="badge bg-secondary">@(roles.FirstOrDefault() ?? "—")</span></td>
      <td>
        <form asp-action="SetRole" method="post" class="d-flex gap-2 align-items-center">
          @Html.AntiForgeryToken()
          <input type="hidden" name="userId" value="@user.Id"/>
          <select name="role" class="form-select form-select-sm" style="width:auto">
            @foreach (var r in (IEnumerable<string?>)ViewBag.AllRoles)
            {
              <option value="@r" selected="@(roles.Contains(r!))">@r</option>
            }
          </select>
          <button type="submit" class="btn btn-sm btn-outline-primary">Зберегти</button>
        </form>
      </td>
    </tr>
  }
  </tbody>
</table>
</div>
