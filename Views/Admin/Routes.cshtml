@model IEnumerable<SolarPath.Web.Models.Route>
@{ViewData["Title"] = "Управління маршрутами";}

<div class="page-header mb-4">
  <h1 class="page-title"><i class="bi bi-signpost-2-fill me-2"></i>Всі маршрути</h1>
  <a asp-controller="Routes" asp-action="Create" class="btn btn-success btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Новий маршрут
  </a>
</div>

<div class="sp-table">
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Назва</th>
        <th>Категорія</th>
        <th>Гід</th>
        <th>Статус</th>
        <th>Ціна</th>
        <th>Дія</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var r in Model) {
        <tr>
          <td>
            <a asp-controller="Routes" asp-action="Details" asp-route-id="@r.Id"
               class="fw-600 text-decoration-none">@r.Title</a>
          </td>
          <td>@r.Category?.Name</td>
          <td>@r.Guide?.FullName</td>
          <td>
            @if (r.RouteStatus == SolarPath.Web.Models.RouteStatus.Published) {
              <span class="badge bg-success">Опублікований</span>
            } else if (r.RouteStatus == SolarPath.Web.Models.RouteStatus.Draft) {
              <span class="badge bg-secondary">Чернетка</span>
            } else {
              <span class="badge bg-danger">Архів</span>
            }
          </td>
          <td class="fw-600">@r.PricePerPerson ₴</td>
          <td>
            <div class="d-flex gap-2">
              <a asp-controller="Routes" asp-action="Edit" asp-route-id="@r.Id"
                 class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil"></i>
              </a>
              <form asp-action="DeleteRoute" asp-route-id="@r.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Видалити маршрут «@r.Title»?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>
