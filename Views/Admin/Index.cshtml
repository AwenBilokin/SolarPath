@{ViewData["Title"] = "Адмін-панель";}

<div style="font-size:1.4rem;font-weight:800;color:#1a2e1f;margin-bottom:4px;">Адміністрування</div>
<div style="font-size:.83rem;color:#6b9275;margin-bottom:24px;">Загальна статистика системи SolarPath</div>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="bi bi-signpost-2-fill"></i></div>
      <div class="stat-value">@ViewBag.RoutesCount</div>
      <div class="stat-label">Маршрутів всього</div>
      <a asp-action="Routes" style="display:block;margin-top:12px;background:#f0fdf4;color:#16a34a;border-radius:8px;padding:5px;text-align:center;font-size:.8rem;font-weight:600;text-decoration:none;">Переглянути →</a>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="bi bi-calendar-check-fill"></i></div>
      <div class="stat-value">@ViewBag.BookingsCount</div>
      <div class="stat-label">Бронювань всього</div>
      <a asp-action="Bookings" style="display:block;margin-top:12px;background:#eff6ff;color:#1d4ed8;border-radius:8px;padding:5px;text-align:center;font-size:.8rem;font-weight:600;text-decoration:none;">Переглянути →</a>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:#f3e8ff;color:#7c3aed;"><i class="bi bi-people-fill"></i></div>
      <div class="stat-value">@ViewBag.UsersCount</div>
      <div class="stat-label">Користувачів</div>
      <a asp-action="Users" style="display:block;margin-top:12px;background:#faf5ff;color:#7c3aed;border-radius:8px;padding:5px;text-align:center;font-size:.8rem;font-weight:600;text-decoration:none;">Переглянути →</a>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:#fef9c3;color:#a16207;"><i class="bi bi-cash-stack"></i></div>
      <div class="stat-value">@ViewBag.TotalRevenue.ToString("N0")</div>
      <div class="stat-label">Дохід, ₴</div>
      <a asp-action="Bookings" style="display:block;margin-top:12px;background:#fefce8;color:#a16207;border-radius:8px;padding:5px;text-align:center;font-size:.8rem;font-weight:600;text-decoration:none;">Деталі →</a>
    </div>
  </div>
</div>

@if (ViewBag.PendingRefunds > 0)
{
  <div class="alert alert-warning d-flex align-items-center gap-2">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <strong>@ViewBag.PendingRefunds запит(ів) на повернення коштів</strong> очікують обробки.
    <a asp-action="Bookings" class="ms-auto btn btn-sm btn-warning">Обробити</a>
  </div>
}
