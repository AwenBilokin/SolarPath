@using SolarPath.Web.Models
@{ViewData["Title"] = "Кабінет гіда";}

<div class="page-header">
  <h1 class="page-title"><i class="bi bi-compass-fill me-2"></i>Кабінет гіда</h1>
  <a asp-controller="Routes" asp-action="Create" class="btn btn-success btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Новий маршрут
  </a>
</div>

<h5 class="section-heading">Мої маршрути</h5>
<div class="sp-table mb-5">
  <table class="table table-hover mb-0">
    <thead>
      <tr><th>Назва</th><th>Статус</th><th>Ціна</th><th>Бронювань</th><th>Дії</th></tr>
    </thead>
    <tbody>
      @foreach (var r in (IEnumerable<Route>)ViewBag.Routes) {
        <tr>
          <td class="fw-600">
            <a asp-controller="Routes" asp-action="Details" asp-route-id="@r.Id"
               class="text-decoration-none">@r.Title</a>
          </td>
          <td>
            @if (r.RouteStatus == RouteStatus.Published) {
              <span class="badge bg-success">Опублікований</span>
            } else if (r.RouteStatus == RouteStatus.Draft) {
              <span class="badge bg-secondary">Чернетка</span>
            } else {
              <span class="badge bg-danger">Архів</span>
            }
          </td>
          <td>@r.PricePerPerson ₴</td>
          <td>@r.Bookings.Count</td>
          <td>
            <div class="d-flex gap-2 flex-wrap">
              <a asp-controller="Routes" asp-action="Edit" asp-route-id="@r.Id"
                 class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Редагувати
              </a>
              @if (r.RouteStatus == RouteStatus.Draft) {
                <form asp-controller="Guide" asp-action="Publish" method="post" asp-route-id="@r.Id">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-success">
                    <i class="bi bi-send me-1"></i>Опублікувати
                  </button>
                </form>
              }
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>

<h5 class="section-heading">Бронювання на мої маршрути</h5>
<div class="sp-table">
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Маршрут</th><th>Турист</th><th>Дата</th>
        <th>Осіб</th><th>Сума</th><th>Статус</th><th>Дії</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var b in (IEnumerable<Booking>)ViewBag.Bookings) {
        <tr>
          <td class="fw-600">@b.Route?.Title</td>
          <td>@b.Tourist?.FullName</td>
          <td>@b.ScheduledDate.ToString("dd.MM.yyyy")</td>
          <td>@b.ParticipantsCount</td>
          <td>@b.TotalPrice ₴</td>
          <td>
            @{
              var (cls, label) = b.BookingStatus switch {
                BookingStatus.Confirmed        => ("bg-primary",           "Підтверджено"),
                BookingStatus.Paid             => ("bg-success",           "Оплачено"),
                BookingStatus.InProgress       => ("bg-info",              "В процесі"),
                BookingStatus.Completed        => ("bg-secondary",         "Завершено"),
                BookingStatus.Cancelled        => ("bg-danger",            "Скасовано"),
                BookingStatus.CancelledByGuide => ("bg-danger",            "Відхилено"),
                BookingStatus.RefundRequested  => ("bg-warning text-dark", "Повернення"),
                BookingStatus.Pending          => ("bg-warning text-dark", "Очікується"),
                _ => ("bg-secondary", b.BookingStatus.ToString())
              };
            }
            <span class="badge @cls">@label</span>
          </td>
          <td>
            <div class="d-flex gap-2 flex-wrap">
              @if (b.BookingStatus == BookingStatus.Paid) {
                <form asp-controller="Guide" asp-action="Confirm" method="post" asp-route-id="@b.Id">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-success">
                    <i class="bi bi-check-lg me-1"></i>Підтвердити
                  </button>
                </form>
                <form asp-controller="Guide" asp-action="Reject" method="post" asp-route-id="@b.Id">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x-lg me-1"></i>Відхилити
                  </button>
                </form>
              }
              @if (b.BookingStatus == BookingStatus.Confirmed) {
                <form asp-controller="Guide" asp-action="Start" method="post" asp-route-id="@b.Id">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-info text-white">
                    <i class="bi bi-play-fill me-1"></i>Розпочати
                  </button>
                </form>
              }
              @if (b.BookingStatus == BookingStatus.InProgress) {
                <form asp-controller="Guide" asp-action="Complete" method="post" asp-route-id="@b.Id">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-secondary">
                    <i class="bi bi-flag-fill me-1"></i>Завершити
                  </button>
                </form>
              }
            </div>
          </td>
        </tr>
      }
    </tbody>
  </table>
</div>
