@model SolarPath.Web.Models.Route
@{ViewData["Title"] = "Редагувати: " + Model.Title;}

<h2 class="mb-4 fw-bold"><i class="bi bi-pencil-fill me-2 text-primary"></i>Редагувати маршрут</h2>
<div class="card shadow p-4">
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
  @Html.AntiForgeryToken()
  <div class="row g-3">
    <div class="col-md-8">
      <label class="form-label fw-semibold">Назва</label>
      <input asp-for="Title" class="form-control" required/>
    </div>
    <div class="col-md-4">
      <label class="form-label fw-semibold">Категорія</label>
      <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
    </div>
    <div class="col-12">
      <label class="form-label fw-semibold">Опис</label>
      <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Складність</label>
      <select asp-for="Difficulty" class="form-select" asp-items="Html.GetEnumSelectList<SolarPath.Web.Models.DifficultyLevel>()"></select>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Відстань (км)</label>
      <input asp-for="DistanceKm" type="number" step="0.1" class="form-control"/>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Тривалість (хв)</label>
      <input asp-for="DurationMinutes" type="number" class="form-control"/>
    </div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Макс. учасників</label>
      <input asp-for="MaxParticipants" type="number" class="form-control"/>
    </div>
    <div class="col-md-4">
      <label class="form-label fw-semibold">Ціна/особу (₴)</label>
      <input asp-for="PricePerPerson" type="number" step="0.01" class="form-control"/>
    </div>
    <div class="col-md-4">
      <label class="form-label fw-semibold">Сезон (початок)</label>
      <input asp-for="SeasonStart" type="date" class="form-control"/>
    </div>
    <div class="col-md-4">
      <label class="form-label fw-semibold">Сезон (кінець)</label>
      <input asp-for="SeasonEnd" type="date" class="form-control"/>
    </div>
    <div class="col-12">
      <label class="form-label fw-semibold">Нове фото (залиш порожнім, щоб не змінювати)</label>
      <input type="file" name="image" class="form-control" accept="image/*"/>
      @if (!string.IsNullOrEmpty(Model.ImageUrl))
      {
        <img src="@Model.ImageUrl" onerror="this.onerror=null;this.src='/images/route-placeholder.svg';" class="mt-2 rounded" style="height:80px;object-fit:cover" alt="preview"/>
      }
    </div>
    <div class="col-12">
      <label class="form-label fw-semibold">GeoJSON</label>
      <textarea asp-for="GeoData" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12 d-flex gap-2">
      <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Зберегти</button>
      <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
    </div>
  </div>
</form>
</div>
