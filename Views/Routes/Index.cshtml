@model IEnumerable<SolarPath.Web.Models.Route>
@{ViewData["Title"] = "Маршрути";}

<div style="font-size:1.2rem;font-weight:700;color:#1a2e1f;letter-spacing:-.02em;">Каталог маршрутів</div>
<div style="font-size:.83rem;color:#6b9275;margin-top:2px;margin-bottom:18px;">Знайдено: @Model.Count() маршрутів</div>

<div class="row g-3">
  <!-- Sidebar -->
  <div class="col-lg-3">
    <div style="background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:14px;padding:18px;position:sticky;top:70px;">
      <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6b9275;margin-bottom:14px;">
        <i class="bi bi-sliders me-1"></i>Фільтри
      </div>
      <form method="get">
        <div style="margin-bottom:12px;">
          <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Категорія</label>
          <select name="categoryId" class="form-select form-select-sm">
            <option value="">Усі категорії</option>
            @foreach (var c in (IEnumerable<SolarPath.Web.Models.Category>)ViewBag.Categories) {
              <option value="@c.Id" selected="@(ViewBag.SelectedCategory != null && ViewBag.SelectedCategory.ToString() == c.Id.ToString())">@c.Name</option>
            }
          </select>
        </div>
        <div style="margin-bottom:12px;">
          <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Складність</label>
          <select name="difficulty" class="form-select form-select-sm">
            <option value="">Будь-яка</option>
            @foreach (var d in Enum.GetValues<SolarPath.Web.Models.DifficultyLevel>()) {
              <option value="@d">@d</option>
            }
          </select>
        </div>
        <div style="margin-bottom:12px;">
          <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Макс. ціна (₴)</label>
          <input type="number" name="maxPrice" class="form-control form-control-sm" value="@ViewBag.MaxPrice" placeholder="Без обмежень"/>
        </div>
        <div style="margin-bottom:16px;">
          <label style="font-size:.8rem;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Пошук</label>
          <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Назва маршруту..."/>
        </div>
        <button type="submit" style="display:block;width:100%;background:#16a34a;color:#fff;border:none;border-radius:8px;padding:8px;font-weight:600;font-size:.855rem;cursor:pointer;font-family:inherit;">
          Застосувати
        </button>
        <a href="/Routes" style="display:block;width:100%;background:none;border:1px solid #e5e7eb;border-radius:8px;padding:7px;font-size:.84rem;color:#6b7280;text-align:center;text-decoration:none;margin-top:8px;">
          Скинути фільтри
        </a>
      </form>
    </div>
  </div>

  <!-- Grid -->
  <div class="col-lg-9">
    @if (!Model.Any()) {
      <div style="background:#e0f2fe;color:#0369a1;border-radius:10px;padding:14px 18px;font-size:.875rem;">
        <i class="bi bi-info-circle me-2"></i>За обраними фільтрами маршрутів не знайдено.
      </div>
    } else {
      <div class="row g-3">
        @foreach (var r in Model) {
          <div class="col-md-6 col-xl-4">
            <a asp-controller="Routes" asp-action="Details" asp-route-id="@r.Id"
               style="text-decoration:none;display:block;height:100%;">
              <div style="background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;height:100%;transition:transform .2s,box-shadow .2s;"
                   onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 14px 36px rgba(22,163,74,.13)'"
                   onmouseout="this.style.transform='';this.style.boxShadow=''">

                <!-- Image -->
                <div style="position:relative;height:175px;overflow:hidden;flex-shrink:0;">
                  <img src="@(r.ImageUrl ?? "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&q=80")"
                       alt="@r.Title" style="width:100%;height:100%;object-fit:cover;display:block;"/>
                  <div style="position:absolute;top:10px;left:10px;z-index:2;">
                    <span class="badge-difficulty badge-@r.Difficulty.ToString().ToLower()">@r.Difficulty</span>
                  </div>
                </div>

                <!-- Body -->
                <div style="padding:13px;display:flex;flex-direction:column;flex:1;">

                  <!-- Meta -->
                  <div style="display:flex;flex-wrap:wrap;gap:7px;font-size:.74rem;color:#6b9275;margin-bottom:7px;">
                    <span><i class="bi bi-tag-fill me-1"></i>@r.Category?.Name</span>
                    <span><i class="bi bi-geo-alt-fill me-1"></i>@r.DistanceKm км</span>
                  </div>

                  <!-- Title -->
                  <div style="font-size:.93rem;font-weight:700;color:#1a2e1f;line-height:1.3;margin-bottom:7px;">
                    @r.Title
                  </div>

                  <!-- Stars -->
                  <div style="font-size:.77rem;color:#f59e0b;margin-bottom:10px;">
                    @for (int i = 1; i <= 5; i++) {
                      <i class="bi @(i <= Math.Round(r.AverageRating) ? "bi-star-fill" : "bi-star")"
                         style="@(i > Math.Round(r.AverageRating) ? "color:#d1d5db;" : "")"></i>
                    }
                    <span style="font-size:.72rem;color:#9ca3af;margin-left:3px;">(@r.Reviews.Count)</span>
                  </div>

                  <!-- Footer -->
                  <div style="display:flex;justify-content:space-between;align-items:center;padding-top:10px;border-top:1px solid #f0f4f0;margin-top:auto;">
                    <div style="font-size:.98rem;font-weight:800;color:#166534;">@r.PricePerPerson ₴</div>
                    <span style="background:#f0fdf4;color:#166534;border-radius:7px;padding:4px 11px;font-size:.77rem;font-weight:600;">
                      Детальніше
                    </span>
                  </div>

                </div>
              </div>
            </a>
          </div>
        }
      </div>
    }
  </div>
</div>
