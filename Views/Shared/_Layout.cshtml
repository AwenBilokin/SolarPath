<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " · SolarPath" : "SolarPath")</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>

<nav class="sp-navbar navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
      <span class="brand-icon"><i class="bi bi-sun-fill"></i></span>
      SolarPath
    </a>

    <div class="sp-search-wrap ms-2 ms-lg-3">
      <button type="button" class="sp-search-toggle" id="searchToggle" aria-label="Пошук маршрутів">
        <i class="bi bi-search"></i>
      </button>
      <div class="sp-search-panel" id="searchPanel">
        <form asp-controller="Routes" asp-action="Index" method="get" autocomplete="off">
          <div class="sp-search-input-wrap">
            <i class="bi bi-search sp-search-icon"></i>
            <input type="text" name="search" id="searchInput" class="sp-search-input"
                   placeholder="Пошук маршрутів, місць, категорій..." />
          </div>
        </form>
        <div id="searchSuggestions" class="sp-search-suggestions"></div>
      </div>
    </div>

    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-controls="navMain" aria-expanded="false">
      <i class="bi bi-list" style="color:#fff;font-size:1.4rem;"></i>
    </button>
    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto gap-1 mt-2 mt-lg-0">
        <li class="nav-item">
          <a class="nav-link" asp-controller="Routes" asp-action="Index">
            <i class="bi bi-signpost-2 me-1"></i>Маршрути
          </a>
        </li>
        @if (User.IsInRole("Guide")) {
          <li class="nav-item">
            <a class="nav-link" asp-controller="Guide" asp-action="Dashboard">
              <i class="bi bi-compass me-1"></i>Кабінет гіда
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" asp-controller="Routes" asp-action="Create">
              <i class="bi bi-plus-circle me-1"></i>Новий маршрут
            </a>
          </li>
        }
        @if (User.IsInRole("Tourist")) {
          <li class="nav-item">
            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">
              <i class="bi bi-calendar-check me-1"></i>Бронювання
            </a>
          </li>
        }
        @if (User.IsInRole("Administrator")) {
          <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Index">
              <i class="bi bi-shield-check me-1"></i>Адмін
            </a>
          </li>
        }
      </ul>
      <ul class="navbar-nav align-items-lg-center gap-2 mt-2 mt-lg-0">
        @if (User.Identity?.IsAuthenticated == true) {
          <li class="nav-item dropdown">
            <a class="nav-link nav-user dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="nav-avatar"><i class="bi bi-person-fill"></i></span>
              <span class="nav-username">@User.Identity.Name</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <form asp-controller="Account" asp-action="Logout" method="post">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="dropdown-item">
                    <i class="bi bi-box-arrow-right me-2 text-danger"></i>Вийти
                  </button>
                </form>
              </li>
            </ul>
          </li>
        } else {
          <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">Увійти</a>
          </li>
          <li class="nav-item">
            <a class="btn-nav-cta" asp-controller="Account" asp-action="Register">Реєстрація</a>
          </li>
        }
      </ul>
    </div>
  </div>
</nav>

<main class="container py-4">
  @if (TempData["Success"] != null) {
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["Error"] != null) {
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @RenderBody()
</main>

<footer class="sp-footer">
  <div class="container text-center">
    <i class="bi bi-sun-fill me-1" style="color:#4ade80;"></i>
    <strong style="color:rgba(255,255,255,.6);">SolarPath</strong>
    <span style="color:rgba(255,255,255,.25);margin:0 8px;">·</span>
    <span>&copy; @DateTime.Now.Year</span>
    <span style="color:rgba(255,255,255,.25);margin:0 8px;">·</span>
    <span>Туристичні маршрути України</span>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  const toggle      = document.getElementById('searchToggle');
  const panel       = document.getElementById('searchPanel');
  const input       = document.getElementById('searchInput');
  const suggestions = document.getElementById('searchSuggestions');

  if (!toggle || !panel || !input || !suggestions) return;

  let debounceTimer = null;
  let activeIndex   = -1;
  let items         = [];

  function openPanel() {
    panel.classList.add('show');
    toggle.classList.add('active');
    setTimeout(() => input.focus(), 50);
  }
  function closePanel() {
    panel.classList.remove('show');
    toggle.classList.remove('active');
    suggestions.innerHTML = '';
    activeIndex = -1;
    items = [];
  }

  toggle.addEventListener('click', (e) => {
    e.stopPropagation();
    panel.classList.contains('show') ? closePanel() : openPanel();
  });

  document.addEventListener('click', (e) => {
    if (!panel.contains(e.target) && !toggle.contains(e.target)) closePanel();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });

  function iconFor(type) {
    return type === 'category' ? 'bi-tags-fill' : 'bi-signpost-2-fill';
  }

  function render(data) {
    items = data || [];
    activeIndex = -1;

    if (items.length === 0) {
      suggestions.innerHTML = input.value.trim().length >= 2
        ? '<div class="sp-suggestion-empty">Нічого не знайдено</div>'
        : '';
      return;
    }

    suggestions.innerHTML = items.map((it, i) => `
      <a href="${it.url}" class="sp-suggestion-item" data-index="${i}">
        <span class="sp-suggestion-icon ${it.type}"><i class="bi ${iconFor(it.type)}"></i></span>
        <span class="sp-suggestion-text">
          <div class="sp-suggestion-title">${escapeHtml(it.title)}</div>
          <div class="sp-suggestion-subtitle">${escapeHtml(it.subtitle)}</div>
        </span>
        ${it.price != null ? `<span class="sp-suggestion-price">${Math.round(it.price)} ₴</span>` : ''}
      </a>
    `).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function fetchSuggestions(query) {
    suggestions.innerHTML = '<div class="sp-suggestion-loading"><i class="bi bi-hourglass-split"></i> Пошук...</div>';
    fetch(`/Routes/Suggestions?q=${encodeURIComponent(query)}`)
      .then(r => r.ok ? r.json() : [])
      .then(render)
      .catch(() => { suggestions.innerHTML = ''; });
  }

  input.addEventListener('input', () => {
    const q = input.value.trim();
    clearTimeout(debounceTimer);

    if (q.length < 2) {
      suggestions.innerHTML = '';
      items = [];
      return;
    }

    debounceTimer = setTimeout(() => fetchSuggestions(q), 220);
  });

  input.addEventListener('keydown', (e) => {
    const els = suggestions.querySelectorAll('.sp-suggestion-item');
    if (els.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % els.length;
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + els.length) % els.length;
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault();
      els[activeIndex].click();
      return;
    } else {
      return;
    }

    els.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
    els[activeIndex].scrollIntoView({ block: 'nearest' });
  });
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
